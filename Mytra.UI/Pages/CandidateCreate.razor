@page "/candidatecreate"
@inject HttpClient Http
@inject NavigationManager NavManager

<h3>CandidateCreate</h3>

@if (Model == null)
{
    <p>Yükleniyor...</p>
}
else
{
    <EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

