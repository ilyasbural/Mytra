@page "/managerauthenticationinfo/{id:guid}"
@inject HttpClient Http

<PageTitle>ManagerAuthentication - @Id</PageTitle>
<h3>ManagerAuthentication - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<ManagerAuthenticationResponse>? Response;

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<ManagerAuthenticationResponse>>("https://localhost:7046/api/candidate");
    }
}