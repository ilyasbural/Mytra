@page "/userdetailupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>UserDetail - @Id</PageTitle>
<h3>UserDetail - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<UserDetailResponse>? Response { get; set; }
    private Common.UserDetailUpdate Model { get; set; } = new Common.UserDetailUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<UserDetailResponse>>
        ($"https://localhost:7046/api/userdetailsingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.UserDetailUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/userdetail", Model);
        NavManager.NavigateTo("/userdetail");
    }
}