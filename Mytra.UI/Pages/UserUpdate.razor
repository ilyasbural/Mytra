@page "/userupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>UserUpdate - @Id</PageTitle>
<h3>UserUpdate - @Id</h3>

@if (Model == null)
{
    <p>Yükleniyor...</p>
}
else
{
    <EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="name">İsim:</label>
            <InputText id="name" @bind-Value="Model.Name" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Kaydet</button>

    </EditForm>
}

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<UserResponse>? Response { get; set; }
    private Common.UserUpdate Model { get; set; } = new Common.UserUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<UserResponse>>
        ($"https://localhost:7046/api/usersingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.UserUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/user", Model);
        NavManager.NavigateTo("/user");
    }
}