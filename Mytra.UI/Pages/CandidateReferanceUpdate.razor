@page "/candidatereferanceupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>CandidateReferance - @Id</PageTitle>
<h3>CandidateReferance - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<CandidateReferanceResponse>? Response { get; set; }
    private Common.CandidateReferanceUpdate Model { get; set; } = new Common.CandidateReferanceUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<CandidateReferanceResponse>>
        ($"https://localhost:7046/api/candidatereferancesingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.CandidateReferanceUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/candidatereferance", Model);
        NavManager.NavigateTo("/candidatereferance");
    }
}