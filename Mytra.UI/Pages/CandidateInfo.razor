@page "/candidateinfo/{id:guid}"
@inject HttpClient Http

<PageTitle>Candidate Detail - @Id</PageTitle>
<h3>Candidate Detail - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<JobPostingResponse>? Response { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<JobPostingResponse>>("https://localhost:7046/api/candidate");
    }
}






