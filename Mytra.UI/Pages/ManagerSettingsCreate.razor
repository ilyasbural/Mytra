    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PostAsJsonAsync("https://localhost:7046/api/managersettings", Model);
        if (Result.IsSuccessStatusCode)
        {
            Response = await Result.Content.ReadFromJsonAsync<ServiceResponse<ManagerSettingsResponse>>();
            if (Response != null && Response.Success) NavManager.NavigateTo("/managersettings");
        }
    }
}