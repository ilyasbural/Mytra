@page "/managerauthenticationupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>ManagerAuthentication - @Id</PageTitle>
<h3>ManagerAuthentication - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<ManagerAuthenticationResponse>? Response { get; set; }
    private Common.ManagerAuthenticationUpdate Model { get; set; } = new Common.ManagerAuthenticationUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<ManagerAuthenticationResponse>>
        ($"https://localhost:7046/api/managerauthenticationsingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.ManagerAuthenticationUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/managerauthentication", Model);
        NavManager.NavigateTo("/managerauthentication");
    }
}