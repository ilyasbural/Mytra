@page "/candidatelanguageupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>CandidateLanguage - @Id</PageTitle>
<h3>CandidateLanguage - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<CandidateLanguageResponse>? Response { get; set; }
    private Common.CandidateLanguageUpdate Model { get; set; } = new Common.CandidateLanguageUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<CandidateLanguageResponse>>
        ($"https://localhost:7046/api/candidatelanguagesingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.CandidateLanguageUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/candidatelanguage", Model);
        NavManager.NavigateTo("/candidatelanguage");
    }
}