@page "/candidateskillsinfo/{id:guid}"
@inject HttpClient Http

<PageTitle>CandidateSkills - @Id</PageTitle>
<h3>CandidateSkills - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<CandidateSkillsResponse>? Response;

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<CandidateSkillsResponse>>("https://localhost:7046/api/candidate");
    }
}