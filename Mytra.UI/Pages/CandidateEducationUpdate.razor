@page "/candidateeducationupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>CandidateEducation - @Id</PageTitle>
<h3>CandidateEducation - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<CandidateEducationResponse>? Response { get; set; }
    private Common.CandidateEducationUpdate Model { get; set; } = new Common.CandidateEducationUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<CandidateEducationResponse>>
        ($"https://localhost:7046/api/candidateeducationsingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.CandidateEducationUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/candidateeducation", Model);
        NavManager.NavigateTo("/candidateeducation");
    }
}