@page "/candidateskillsupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>CandidateSkills - @Id</PageTitle>
<h3>CandidateSkills - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<CandidateSkillsResponse>? Response { get; set; }
    private Common.CandidateSkillsUpdate Model = new Common.CandidateSkillsUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<CandidateSkillsResponse>>
        ($"https://localhost:7046/api/candidateskillssingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.CandidateSkillsUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/candidateskills", Model);
        NavManager.NavigateTo("/candidateskills");
    }
}