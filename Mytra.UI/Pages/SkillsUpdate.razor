@page "/skillsupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Skills - @Id</PageTitle>
<h3>Skills - @Id</h3>

<h3>Kişi Güncelle</h3>

@if (Model == null)
{
    <p>Yükleniyor...</p>
}
else
{
    <EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="name">İsim:</label>
            <InputText id="name" @bind-Value="Model.Name" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Kaydet</button>
    </EditForm>
}

@code
{
    [Parameter] 
    public Guid Id { get; set; }
    ServiceResponse<SkillsResponse>? Response { get; set; }
    Common.SkillsUpdate Model { get; set; } = new Common.SkillsUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<SkillsResponse>>
        ($"https://localhost:7046/api/skillssingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.SkillsUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        await Http.PutAsJsonAsync("https://localhost:7046/api/skills", Model);
        NavManager.NavigateTo("/skills");
    }
}