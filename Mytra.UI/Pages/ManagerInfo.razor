@page "/managerinfo/{id:guid}"
@inject HttpClient Http

<PageTitle>Manager - @Id</PageTitle>
<h3>Manager - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<ManagerResponse>? Response;
    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<ManagerResponse>>("https://localhost:7046/api/candidate");
    }
}