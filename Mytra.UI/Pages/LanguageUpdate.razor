@page "/languageupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>Language - @Id</PageTitle>
<h3>Language - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<LanguageResponse>? Response { get; set; }
    private Common.LanguageUpdate Model { get; set; } = new Common.LanguageUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<LanguageResponse>>
        ($"https://localhost:7046/api/languagesingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.LanguageUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/language", Model);
        NavManager.NavigateTo("/language");
    }
}