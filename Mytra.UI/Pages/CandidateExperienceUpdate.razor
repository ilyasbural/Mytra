@page "/candidateexperienceupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>CandidateExperience - @Id</PageTitle>
<h3>CandidateExperience - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<CandidateExperienceResponse>? Response { get; set; }
    private Common.CandidateExperienceUpdate Model { get; set; } = new Common.CandidateExperienceUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<CandidateExperienceResponse>>
        ($"https://localhost:7046/api/candidateexperiencesingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.CandidateExperienceUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/candidateexperience", Model);
        NavManager.NavigateTo("/candidateexperience");
    }
}