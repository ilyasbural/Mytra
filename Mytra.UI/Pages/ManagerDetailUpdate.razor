@page "/managerdetailupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>ManagerDetail - @Id</PageTitle>
<h3>ManagerDetail - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<ManagerDetailResponse>? Response { get; set; }
    private Common.ManagerDetailUpdate Model { get; set; } = new Common.ManagerDetailUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<ManagerDetailResponse>>
        ($"https://localhost:7046/api/managerdetailsingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.ManagerDetailUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/managerdetail", Model);
        NavManager.NavigateTo("/managerdetail");
    }
}