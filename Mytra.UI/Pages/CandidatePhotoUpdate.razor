@page "/candidatephotoupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>CandidatePhoto - @Id</PageTitle>
<h3>CandidatePhoto - @Id</h3>

@if (CandidatePhoto == null)
{
    <p>Yükleniyor...</p>
}
else
{
    <EditForm Model="CandidatePhoto" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label for="name">İsim:</label>
            <InputText id="name" @bind-Value="CandidatePhoto.Name" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Kaydet</button>
    </EditForm>
}

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<CandidatePhotoResponse>? Response { get; set; }
    private Common.CandidatePhotoUpdate CandidatePhoto { get; set; } = new Common.CandidatePhotoUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<CandidatePhotoResponse>>
        ($"https://localhost:7046/api/candidatephotosingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            CandidatePhoto = new Common.CandidatePhotoUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        await Http.PutAsJsonAsync("https://localhost:7046/api/candidatephoto", CandidatePhoto);
        NavManager.NavigateTo("/candidatephoto");
    }
}