@page "/collegeinfo/{id:guid}"
@inject HttpClient Http

<PageTitle>College - @Id</PageTitle>
<h3>College - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<CollegeResponse>? Response;

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<CollegeResponse>>("https://localhost:7046/api/candidate");
    }
}