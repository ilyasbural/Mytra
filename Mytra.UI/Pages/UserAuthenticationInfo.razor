@page "/userauthenticationinfo"
@inject HttpClient Http

<PageTitle>UserAuthentication</PageTitle>
<h3>UserAuthentication</h3>

@code
{
    private ServiceResponse<UserAuthenticationResponse>? Response;
    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<UserAuthenticationResponse>>("https://localhost:7046/api/candidate");
    }
}