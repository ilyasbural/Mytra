@page "/candidateeducationcreate"
@inject HttpClient Http

<h3>CandidateEducationCreate</h3>
@* <input placeholder="İsim" @bind="newPerson.Name" />
<input placeholder="Yaş" type="number" @bind="newPerson.Age" /> *@
<button @onclick="Save">Kaydet</button>
<p>@Message</p>

@code
{
    String Message = String.Empty;
    ServiceResponse<CandidateEducationResponse>? Response { get; set; }
    CandidateEducationInsert CandidateAuthentication = new CandidateEducationInsert();

    private async Task Save()
    {
        HttpResponseMessage httpResponse = await Http.PostAsJsonAsync("https://localhost:7046/api/candidateeducation", CandidateAuthentication);

        if (httpResponse.IsSuccessStatusCode)
        {
            Response = await httpResponse.Content.ReadFromJsonAsync<ServiceResponse<CandidateEducationResponse>>();

            if (Response != null && Response.Success) Message = "Kayıt başarıyla eklendi!";
            else Message = "Kayıt başarısız oldu!";
        }
        else Message = $"API hata döndü: {httpResponse.StatusCode}";
    }
}