@page "/usersettingsupdate/{id:guid}"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>UserSettings - @Id</PageTitle>
<h3>UserSettings - @Id</h3>

@code
{
    [Parameter]
    public Guid Id { get; set; }
    private ServiceResponse<UserSettingsResponse>? Response { get; set; }
    private Common.UserSettingsUpdate Model { get; set; } = new Common.UserSettingsUpdate();

    protected override async Task OnInitializedAsync()
    {
        Response = await Http.GetFromJsonAsync<ServiceResponse<UserSettingsResponse>>
        ($"https://localhost:7046/api/usersettingssingle?id={Id}");

        if (Response != null && Response.Data != null)
        {
            Model = new Common.UserSettingsUpdate
            {
                Id = Response.Data.Id,
                Name = Response.Data.Name
            };
        }
    }

    private async Task HandleValidSubmit()
    {
        HttpResponseMessage Result = await Http.PutAsJsonAsync("https://localhost:7046/api/usersettings", Model);
        NavManager.NavigateTo("/usersettings");
    }
}